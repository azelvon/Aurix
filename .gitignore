# --- SISTEM OPERASI (OS) ---
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# --- IDE & TEXT EDITOR ---
# Editor Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# Editor Cursor (berbasis VS Code)
.cursor/

# Editor Antigravity
.antigravity/

# --- FILE PHP & BACKEND ---
# File konfigurasi sensitif (Wajib diabaikan!)
.env
.env.local
.env.*.local
config.local.php

# File log dan sesi PHP
*.log
npm-debug.log*
yarn-debug.log*
php_errors.log

# Kumpulan dependensi jika ada Composer nantinya
/vendor/

# --- FILE JAVASCRIPT & FRONTEND ---
# Folder modul jika menggunakan package eksternal
node_modules/
bower_components/

# Folder hasil build jika menggunakan compiler/bundler
dist/
build/
.sass-cache/

# --- FILE SEMENTARA & PERCOBAAN ---
*.tmp
*.bak
*.swp
